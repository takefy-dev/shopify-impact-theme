{% doc %}
  @prompt
    Créer une section avec un tableau comparatif modifiable.
    
    Ajouter un titre modifiable (taille modifiable) au-dessus du tableau.
    
    Le tableau doit contenir 3 colonnes :
    - première colonne : caractéristiques
    - deuxième colonne : notre produit
    - troisième colonne : bouillotte classique
    
    Ajouter 4 lignes avec :
    - Utilisation mains libres
    - Chaleur continue et ciblée
    - Rechargeable & durable
    - Idéale en déplacement
    
    Dans le tableau :
    - utiliser des icônes ✓ et ✕
    - permettre de modifier facilement le texte et les icônes
    
    Design :
    - style moderne, propre et premium
    - couleurs douces (rose / blanc)
    - coins légèrement arrondis
    - espacement équilibré
    
    IMPORTANT :
    - le tableau doit être responsive (adapté mobile)
    - sur téléphone : lisible, bien espacé, pas collé aux bords
    
    Permettre de modifier facilement le contenu dans Shopify sans code., Améliorer le design du tableau comparatif :
    
    - Rendre les croix (✕) plus visibles avec une couleur rouge douce (#ff4d6d)
    - Garder les coches (✓) en rose mais bien visibles
    
    - Ajouter de l’espace à gauche dans la colonne "caractéristiques" (padding gauche) pour éviter que le texte soit collé au bord
    
    - Ajouter un fond léger pour le tableau (rose très clair ou blanc cassé) pour créer un effet encadré
    
    - Ajouter des coins arrondis au tableau pour un effet plus premium
    
    - Améliorer la séparation entre les lignes (lignes légèrement visibles ou espacement plus grand)
    
    - Centrer verticalement les icônes ✓ et ✕ dans chaque case
    
    - S’assurer que le tableau est bien lisible sur mobile avec du padding sur les côtés
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 20px;
    display: block;
  }

  .ai-comparison-table__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 30px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    padding: 8px;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background-color: #ffffff;
    border-radius: calc({{ block.settings.border_radius }}px - 4px);
    overflow: hidden;
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }} {
    padding: 20px 15px;
    text-align: center;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    font-size: 16px;
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    padding-left: 24px;
  }

  .ai-comparison-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_alternate_background }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }} {
    padding: 20px 15px;
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: 15px;
    vertical-align: middle;
  }

  .ai-comparison-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 500;
    padding-left: 24px;
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} {
    font-size: 26px;
    line-height: 1;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-table__icon-{{ ai_gen_id }}--check {
    color: {{ block.settings.check_color }};
  }

  .ai-comparison-table__icon-{{ ai_gen_id }}--cross {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-comparison-table__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.75);
      margin-bottom: 20px;
    }

    .ai-comparison-table__wrapper-{{ ai_gen_id }} {
      padding: 6px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }} {
      padding: 15px 12px;
      font-size: 14px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }}:first-child {
      font-size: 12px;
      padding-left: 16px;
    }

    .ai-comparison-table__cell-{{ ai_gen_id }} {
      padding: 16px 12px;
      font-size: 13px;
    }

    .ai-comparison-table__cell-{{ ai_gen_id }}:first-child {
      padding-left: 16px;
    }

    .ai-comparison-table__icon-{{ ai_gen_id }} {
      font-size: 22px;
    }
  }
{% endstyle %}

<div class="ai-comparison-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-comparison-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-comparison-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-comparison-table__table-{{ ai_gen_id }}">
      <thead class="ai-comparison-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_1_header }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_2_header }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.column_3_header }}</th>
        </tr>
      </thead>
      <tbody>
        <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">{{ block.settings.row_1_feature }}</td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_1_col_2 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_1_col_3 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
        </tr>
        <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">{{ block.settings.row_2_feature }}</td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_2_col_2 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_2_col_3 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
        </tr>
        <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">{{ block.settings.row_3_feature }}</td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_3_col_2 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_3_col_3 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
        </tr>
        <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">{{ block.settings.row_4_feature }}</td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_4_col_2 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
          <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
            {% if block.settings.row_4_col_3 == 'check' %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--check">✓</span>
            {% else %}
              <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__icon-{{ ai_gen_id }}--cross">✕</span>
            {% endif %}
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

