{% doc %}
  @prompt
    Créer une section avec un titre modifiable et un sous-titre modifiable.
    
    Ajouter en dessous 3 vidéos maximum affichées en ligne.
    
    Les vidéos doivent :
    - être en format vertical (ratio 9:16)
    - avoir des coins arrondis
    - être de taille moyenne (ni trop grandes ni trop petites)
    - être bien espacées entre elles
    
    Disposition :
    - sur ordinateur : les 3 vidéos sont alignées horizontalement
    - sur mobile : affichage en scroll horizontal ou en colonne
    
    IMPORTANT :
    - laisser de l’espace sur les côtés (padding) pour que le contenu ne soit pas collé aux bords
    - espacement équilibré entre les éléments
    
    Style :
    - design moderne, esthétique et premium
    - adapté à une marque beauté
    - contenu centré et facile à lire
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-section-{{ ai_gen_id }} {
    width: 100%;
    padding: 40px 20px;
    display: block;
  }

  .ai-video-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-video-section__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-video-section__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .ai-video-section__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-video-section__videos-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_spacing }}px;
    justify-content: center;
    align-items: flex-start;
  }

  .ai-video-section__video-wrapper-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.video_width }}px;
    max-width: 100%;
  }

  .ai-video-section__video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .ai-video-section__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-section__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
    position: relative;
  }

  .ai-video-section__placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-video-section__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 20px;
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    .ai-video-section-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-video-section__header-{{ ai_gen_id }} {
      margin-bottom: 30px;
    }

    .ai-video-section__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-video-section__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    {% if block.settings.mobile_layout == 'scroll' %}
      .ai-video-section__videos-{{ ai_gen_id }} {
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-bottom: 10px;
        justify-content: flex-start;
      }

      .ai-video-section__videos-{{ ai_gen_id }}::-webkit-scrollbar {
        display: none;
      }

      .ai-video-section__video-wrapper-{{ ai_gen_id }} {
        width: {{ block.settings.video_width | times: 0.7 }}px;
        flex-shrink: 0;
      }
    {% else %}
      .ai-video-section__videos-{{ ai_gen_id }} {
        flex-direction: column;
        align-items: center;
      }

      .ai-video-section__video-wrapper-{{ ai_gen_id }} {
        width: 100%;
        max-width: {{ block.settings.video_width | times: 0.8 }}px;
      }
    {% endif %}
  }
{% endstyle %}

<video-section-{{ ai_gen_id }} class="ai-video-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-section__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-video-section__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-video-section__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-video-section__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-video-section__videos-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign video = block.settings[video_key]
        %}

        {% if video != blank or i == 1 %}
          <div class="ai-video-section__video-wrapper-{{ ai_gen_id }}">
            <div class="ai-video-section__video-container-{{ ai_gen_id }}">
              {% if video != blank %}
                {% if video.sources[1].url %}
                  <video
                    class="ai-video-section__video-{{ ai_gen_id }}"
                    playsinline
                    autoplay
                    muted
                    loop
                  >
                    <source src="{{ video.sources[1].url }}" type="{{ video.sources[1].mime_type }}">
                    <source src="{{ video.sources[0].url }}" type="{{ video.sources[0].mime_type }}">
                  </video>
                {% else %}
                  <video
                    class="ai-video-section__video-{{ ai_gen_id }}"
                    playsinline
                    autoplay
                    muted
                    loop
                    src="{{ video.sources[0].url }}"
                  ></video>
                {% endif %}
              {% else %}
                <div class="ai-video-section__placeholder-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                  </svg>
                  <div class="ai-video-section__empty-state-{{ ai_gen_id }}">
                    Ajouter une vidéo
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</video-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-video-section__video-{{ ai_gen_id }}');
        this.setupIntersectionObserver();
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.play();
            } else {
              entry.target.pause();
            }
          });
        }, options);

        this.videos.forEach((video) => {
          observer.observe(video);
        });
      }
    }

    customElements.define('video-section-{{ ai_gen_id }}', VideoSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Vidéos verticales",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titre",
      "default": "Découvrez nos vidéos"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Une sélection de nos meilleurs moments"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur ordinateur",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Vidéos"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "Vidéo 1"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "Vidéo 2"
    },
    {
      "type": "video",
      "id": "video_3",
      "label": "Vidéo 3"
    },
    {
      "type": "range",
      "id": "video_width",
      "label": "Largeur des vidéos",
      "min": 200,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "video_spacing",
      "label": "Espacement entre vidéos",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Disposition mobile"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Affichage mobile",
      "options": [
        {
          "value": "scroll",
          "label": "Défilement horizontal"
        },
        {
          "value": "column",
          "label": "Colonne verticale"
        }
      ],
      "default": "scroll"
    },
    {
      "type": "header",
      "content": "Style du titre"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille du titre",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Taille du sous-titre",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Couleur du sous-titre",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Vidéos verticales"
    }
  ]
}
{% endschema %}
