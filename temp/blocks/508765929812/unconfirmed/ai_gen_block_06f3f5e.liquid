{% doc %}
  @prompt
    Créer une section avec une image à droite et du texte à gauche sur ordinateur.
    
    Le texte doit contenir :
    - un titre
    - un sous-titre
    - un paragraphe
    
    Le texte doit être bien aligné, lisible et centré verticalement.
    
    IMPORTANT :
    - Ajouter de l’espace autour du texte (padding à gauche et à droite d’au moins 20 à 30px)
    - Le texte ne doit jamais être collé aux bords de l’écran
    
    Image :
    - L’image doit être légèrement plus petite que le texte
    - Coins légèrement arrondis
    - Aspect propre et esthétique
    
    Responsive mobile :
    - Sur téléphone, l’image doit être en haut et le texte en dessous
    - Le texte doit rester bien espacé des bords (padding mobile aussi)
    - Le contenu doit être centré et facile à lire
    
    Style :
    - Design moderne, minimaliste et premium
    - Adapté à une marque beauté
    - Espacement équilibré entre les éléments
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_mobile }}px 0;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    gap: {{ block.settings.gap }}px;
    align-items: center;
    padding: 0 {{ block.settings.horizontal_padding_mobile }}px;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    padding: {{ block.settings.text_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-image-text-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    line-height: 1.2;
    margin: 0;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-image-text-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size_mobile }}px;
    line-height: 1.4;
    margin: 0;
    color: {{ block.settings.subtitle_color }};
    font-weight: 500;
  }

  .ai-image-text-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size_mobile }}px;
    line-height: 1.6;
    margin: 0;
    color: {{ block.settings.paragraph_color }};
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-image-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 0;
    }

    .ai-image-text-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding_desktop }}px;
    }

    .ai-image-text-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }

    .ai-image-text-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_desktop }}px;
    }

    .ai-image-text-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      order: -1;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
    }
  }
{% endstyle %}

<ai-image-text-{{ ai_gen_id }} class="ai-image-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-image-text-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <h3 class="ai-image-text-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</h3>
      {% endif %}

      {% if block.settings.paragraph != blank %}
        <div class="ai-image-text-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
      {% endif %}
    </div>

    <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-text-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
            Ajoutez une image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</ai-image-text-{{ ai_gen_id }}>

<script>
  (function() {
    class AiImageText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('ai-image-text-{{ ai_gen_id }}', AiImageText{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image et texte",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Titre",
      "default": "<p>Découvrez notre collection</p>"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "<p>Des produits de beauté premium</p>"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Paragraphe",
      "default": "<p>Explorez notre sélection soigneusement choisie de produits de beauté haut de gamme, conçus pour sublimer votre routine quotidienne avec élégance et efficacité.</p>"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximale",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement (desktop)",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Espacement (mobile)",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "section_padding_desktop",
      "label": "Padding vertical (desktop)",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "label": "Padding vertical (mobile)",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "horizontal_padding_desktop",
      "label": "Padding horizontal (desktop)",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "horizontal_padding_mobile",
      "label": "Padding horizontal (mobile)",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "text_padding",
      "label": "Padding du texte",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Espacement entre textes",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "mobile_text_alignment",
      "label": "Alignement texte (mobile)",
      "options": [
        {
          "value": "left",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Taille titre (desktop)",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Taille titre (mobile)",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Taille sous-titre (desktop)",
      "min": 16,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Taille sous-titre (mobile)",
      "min": 14,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "paragraph_size_desktop",
      "label": "Taille paragraphe (desktop)",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "paragraph_size_mobile",
      "label": "Taille paragraphe (mobile)",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Sous-titre",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "paragraph_color",
      "label": "Paragraphe",
      "default": "#4a4a4a"
    }
  ],
  "presets": [
    {
      "name": "Image et texte"
    }
  ]
}
{% endschema %}
