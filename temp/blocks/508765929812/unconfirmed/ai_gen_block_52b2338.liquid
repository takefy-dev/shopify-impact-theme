      "min": 14,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Taille (desktop)",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Couleur",
      "default": "#666666"
