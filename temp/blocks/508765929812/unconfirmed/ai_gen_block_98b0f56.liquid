{% doc %}
  @prompt
    Créer une section avec une image à droite et du texte à gauche sur ordinateur.
    
    Le texte doit contenir :
    - un titre
    - un sous-titre
    - un paragraphe
    
    Le texte doit être bien aligné, lisible et centré verticalement.
    
    IMPORTANT :
    - Ajouter de l’espace autour du texte (padding à gauche et à droite d’au moins 20 à 30px)
    - Le texte ne doit jamais être collé aux bords de l’écran
    
    Image :
    - L’image doit être légèrement plus petite que le texte
    - Coins légèrement arrondis
    - Aspect propre et esthétique
    
    Responsive mobile :
    - Sur téléphone, l’image doit être en haut et le texte en dessous
    - Le texte doit rester bien espacé des bords (padding mobile aussi)
    - Le contenu doit être centré et facile à lire
    
    Style :
    - Design moderne, minimaliste et premium
    - Adapté à une marque beauté
    - Espacement équilibré entre les éléments
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 40px;
    align-items: center;
    padding: 60px 0;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    padding: 0 30px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-image-text-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
    font-weight: 600;
  }

  .ai-image-text-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.4;
    font-weight: 500;
  }

  .ai-image-text-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    color: {{ block.settings.paragraph_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
      padding: 40px 0;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      order: 2;
      padding: 0 20px;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      order: 1;
      padding: 0 20px;
    }

    .ai-image-text-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-image-text-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-image-text-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-image-text-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <h3 class="ai-image-text-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</h3>
      {% endif %}

      {% if block.settings.paragraph != blank %}
        <div class="ai-image-text-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
      {% endif %}
    </div>

    <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-text-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
            Ajoutez une image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image et texte",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Titre",
      "default": "Votre titre ici"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Un sous-titre élégant"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Paragraphe",
      "default": "<p>Découvrez notre collection exclusive de produits beauté, conçus avec soin pour sublimer votre routine quotidienne.</p>"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur ordinateur",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "text_spacing",
      "label": "Espacement entre les textes",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style du titre"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Style du sous-titre"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Taille",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Couleur",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Style du paragraphe"
    },
    {
      "type": "range",
      "id": "paragraph_size",
      "label": "Taille",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "paragraph_color",
      "label": "Couleur",
      "default": "#666666"
    }
  ],
  "presets": [
    {
      "name": "Image et texte"
    }
  ]
}
{% endschema %}
