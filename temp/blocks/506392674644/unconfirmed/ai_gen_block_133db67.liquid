{% doc %}
  @prompt
    avis clients et photo
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-customer-reviews-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-customer-reviews__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-customer-reviews__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-customer-reviews__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-customer-reviews__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 32px;
  }

  .ai-customer-reviews__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-customer-reviews__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
  }

  .ai-customer-reviews__card-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ai-customer-reviews__avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background-color: #f4f4f4;
  }

  .ai-customer-reviews__avatar-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-customer-reviews__avatar-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, {{ block.settings.primary_color }} 0%, {{ block.settings.secondary_color }} 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 18px;
  }

  .ai-customer-reviews__info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-customer-reviews__name-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
  }

  .ai-customer-reviews__rating-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-customer-reviews__star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-customer-reviews__star-{{ ai_gen_id }}--empty {
    color: #e0e0e0;
  }

  .ai-customer-reviews__text-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
  }

  .ai-customer-reviews__photo-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    border-radius: {{ block.settings.photo_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-customer-reviews__photo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-customer-reviews__photo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-customer-reviews__photo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-customer-reviews__date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    margin-top: 12px;
  }

  @media screen and (max-width: 749px) {
    .ai-customer-reviews__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-customer-reviews__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }
{% endstyle %}

<customer-reviews-{{ ai_gen_id }} class="ai-customer-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-customer-reviews__header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-customer-reviews__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <p class="ai-customer-reviews__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="ai-customer-reviews__grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign name_key = 'review_' | append: i | append: '_name'
        assign rating_key = 'review_' | append: i | append: '_rating'
        assign text_key = 'review_' | append: i | append: '_text'
        assign photo_key = 'review_' | append: i | append: '_photo'
        assign avatar_key = 'review_' | append: i | append: '_avatar'
        assign date_key = 'review_' | append: i | append: '_date'

        assign name = block.settings[name_key]
        assign rating = block.settings[rating_key]
        assign text = block.settings[text_key]
        assign photo = block.settings[photo_key]
        assign avatar = block.settings[avatar_key]
        assign date = block.settings[date_key]
      %}

      <div class="ai-customer-reviews__card-{{ ai_gen_id }}">
        <div class="ai-customer-reviews__card-header-{{ ai_gen_id }}">
          <div class="ai-customer-reviews__avatar-{{ ai_gen_id }}">
            {% if avatar %}
              <img
                src="{{ avatar | image_url: width: 96 }}"
                alt="{{ name | escape }}"
                width="48"
                height="48"
                loading="lazy"
              >
            {% else %}
              <div class="ai-customer-reviews__avatar-placeholder-{{ ai_gen_id }}">
                {% if name != blank %}
                  {{ name | slice: 0 | upcase }}
                {% else %}
                  ?
                {% endif %}
              </div>
            {% endif %}
          </div>

          <div class="ai-customer-reviews__info-{{ ai_gen_id }}">
            <h3 class="ai-customer-reviews__name-{{ ai_gen_id }}">
              {% if name != blank %}
                {{ name }}
              {% else %}
                Client {{ i }}
              {% endif %}
            </h3>
            <div class="ai-customer-reviews__rating-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <svg class="ai-customer-reviews__star-{{ ai_gen_id }} {% if star > rating %}ai-customer-reviews__star-{{ ai_gen_id }}--empty{% endif %}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
          </div>
        </div>

        {% if text != blank %}
          <div class="ai-customer-reviews__text-{{ ai_gen_id }}">{{ text }}</div>
        {% endif %}

        {% if photo %}
          <div class="ai-customer-reviews__photo-{{ ai_gen_id }}">
            <img
              src="{{ photo | image_url: width: 600 }}"
              alt="Photo de {{ name | escape }}"
              width="600"
              height="400"
              loading="lazy"
            >
          </div>
        {% else %}
          <div class="ai-customer-reviews__photo-{{ ai_gen_id }}">
            <div class="ai-customer-reviews__photo-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}

        {% if date != blank %}
          <div class="ai-customer-reviews__date-{{ ai_gen_id }}">{{ date }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</customer-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviews{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-customer-reviews__card-{{ ai_gen_id }}');
        this.setupObserver();
      }

      setupObserver() {
        const options = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, options);

        this.cards.forEach((card) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(20px)';
          card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(card);
        });
      }
    }

    customElements.define('customer-reviews-{{ ai_gen_id }}', CustomerReviews{{ ai_gen_id }});
  })();
</script>

